<Alloy>
    <Window module="xp.ui" id="index" onClose="onClose" onOpen="onOpen">
        <Widget src="org.piwik.headerbar" 
                id="headerBar" 
                onBack="close"
                 />

        <TableView id="aboutPiwikTable">
            <TableViewRow id="website" onClick="openWebsite"/>
            <TableViewRow id="participate" onClick="participate"/>
            <TableViewRow id="license" onClick="openLicense"/>
            <TableViewRow id="follow" onClick="followPiwik" />
            <TableViewRow id="sourceCode" onClick="openSourceCode"/>
            <TableViewRow id="issues" onClick="openIssues" />
        </TableView>
    </Window>
</Alloy>

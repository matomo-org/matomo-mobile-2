<Alloy>
    <Collection src="piwikSegments" id="piwikSegments" instance="true"/>
    <NavigationWindow id="index"  formFactor="handheld">
        <Window id="indexWin" onClose="onClose" onOpen="onOpen">
            <LeftNavButton>
                <Button id="cancelButton" onClick="closeWindow"/>
            </LeftNavButton>

            <View id="loading"><Label id="loadingLabel"></Label></View>

            <View id="content">
                <TableView id="segmentsTable" onClick="selectSegment">
                </TableView>
            </View>
        </Window>
    </NavigationWindow>
    <Popover class="iOSContainer" id="index" onOpen="onOpen"  formFactor="tablet" width="320" height="400">
        <ContentView>
            <View id="loading"><Label id="loadingLabel"></Label></View>

            <View id="content">
                <TableView id="segmentsTable" onClick="selectSegment">
                </TableView>
            </View>
        </ContentView>
    </Popover>
</Alloy>

"#index": {
    backgroundImage: 'tableviewsection_background_dark.png',
    height: Ti.UI.SIZE,
}

"#index[platform=ios]": {
    selectionStyle: Ti.UI.iOS.TableViewCellSelectionStyle.NONE,
}

"#title": {
    top: 8,
    left: 10,
    wordWrap: true,
    ellipsize: false,
    color: '#eff0f1',
    font: {fontSize: 13},
    right: 10,
    height: Ti.UI.SIZE,
    bottom: 8,
    textTransform: 'uppercase'
}
"#title[platform=ios]": {
    left: 15,
}

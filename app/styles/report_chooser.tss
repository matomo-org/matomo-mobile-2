    right: '8dp',
}

".header": {
    layout: 'vertical',
    height: Ti.UI.SIZE,
    width: Ti.UI.FILL,
    backgroundColor: '#0e1328',
}

".separator": {
    height: 1,
    width: Ti.UI.FILL,
    backgroundColor: '#0f1429'
}

".separator[platform=android]": {
    height: '1dp',
}

"#index": {
    backgroundColor: '#0e1328',
    backgroundSelectedColor: '#0e1328',
    backgroundFocusedColor: 'black',
    height: Ti.UI.SIZE,
}

"#title": {
    top: 12,
    left: 10,
    wordWrap: true,
    ellipsize: false,
    color: '#eff0f1',
    font: {fontSize: 15},
    right: 10,
    height: Ti.UI.SIZE,
    bottom: 12
}

"#title[platform=ios]": {
    left: 15,
    top: 17,
    bottom: 17
}

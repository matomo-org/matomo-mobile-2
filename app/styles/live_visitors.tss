"#index": {
    title: L('Live_VisitorsInRealTime')
}

"#index[formFactor=handheld]": {
    backButtonTitleImage: 'blank.png'
}

"#index[formFactor=tablet]": {
    hidesBackButton: true
}

"#liveTable": {
    separatorColor: '#e0e0e0'
}

"#liveTable[platform=ios]": {
    tableSeparatorInsets: {left:0,right:0}
}

"#loadingindicator": {
    rounded: true
}

"#content": {
    layout: 'vertical'
}

